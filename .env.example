# Dropbox KB Auto - Environment Variables
# Copy this to ~/.openclaw/.env and fill in your credentials

# Dropbox App Credentials
# Create app at: https://www.dropbox.com/developers/apps
# Permissions needed: files.metadata.read, files.content.read

DROPBOX_FULL_APP_KEY=your_app_key_here
DROPBOX_FULL_APP_SECRET=your_app_secret_here
DROPBOX_FULL_REFRESH_TOKEN=your_refresh_token_here

# How to get refresh token:
# 1. Use Dropbox OAuth 2 PKCE flow
# 2. Or use official Dropbox Python SDK: dropbox.oauth.get_refresh_token()
# 3. Store the refresh token here (never commit to git)

# Optional: GitHub token for automated commits (if using git-based features)
# GITHUB_TOKEN=your_github_token_here
